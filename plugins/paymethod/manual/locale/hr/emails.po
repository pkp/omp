msgid "emails.manualPaymentNotification.subject"
msgstr "Obavijest o ručnom plaćanju"

msgid "emails.manualPaymentNotification.body"
msgstr ""
"Ručno plaćanje mora biti obrađeno za tisak {$contextName} i korisnika "
"{$senderName} (username &quot;{$senderUsername}&quot;).<br />\n"
"<br />\n"
"Predmet koji se plaća &quot;{$paymentName}&quot;.<br />\n"
"Cijena {$paymentAmount} ({$paymentCurrencyCode}).<br />\n"
"<br />\n"
"Ovu je e-poruku generirao dodatak za ručno plaćanje Open Monograph Press-a."

msgid "emails.manualPaymentNotification.description"
msgstr ""
"Ovaj predložak e-pošte koristi se za obavještavanje voditelijca/ice "
"izdavačke djelatnosti da je zatraženo ručno plaćanje."

msgid "emailTemplate.variable.manualPaymentPlugin.senderUsername"
msgstr "Korisničko ime platitelja"
